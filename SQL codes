-- total new infections for afghanistan
select location,
sum(new_cases) from `portfolio_project`.`coviddeaths 2`

where location = 'Afghanistan';

-- daily totals only
SELECT 
    location,
    date,
    SUM(new_cases) AS daily_new_cases
FROM `portfolio_project`.`coviddeaths 2`
WHERE location = 'Afghanistan'
GROUP BY location, date
ORDER BY date;
-- “look back” at the previous row’s value.
-- This way, you can compare today’s cases to yesterday’s cases,
-- so -- previous days' case
SELECT 
    location,
    date,
    new_cases,
    LAG(new_cases, 1) OVER (PARTITION BY location ORDER BY date) AS previous_day_cases
FROM `portfolio_project`.`coviddeaths 2`
WHERE location = 'Afghanistan'
ORDER BY date;

-- lagged 2 days
SELECT 
    location,
    date,
    new_cases,
    LAG(new_cases, 2) OVER (PARTITION BY location ORDER BY date) AS previous_2days_cases
FROM `portfolio_project`.`coviddeaths 2`
WHERE location = 'Afghanistan'
ORDER BY date;

-- Calculate Day-to-Day Change (Difference)
SELECT
    location,
    date,
    new_cases,
    LAG(new_cases) OVER (PARTITION BY location ORDER BY date) AS prev_day,
    new_cases - LAG(new_cases) OVER (PARTITION BY location ORDER BY date) AS daily_change
FROM `portfolio_project`.`coviddeaths 2`
ORDER BY date;
SELECT *
FROM `portfolio_project`.`coviddeaths 2`

-- Daily Difference Using LAG()
-- LAG(new_cases, 1) gets yesterday’s cases.
-- difference_from_yesterday subtracts yesterday’s cases from today’s.

SELECT 
    location,
    date,
    new_cases,
    LAG(new_cases, 1) OVER (PARTITION BY location ORDER BY date) AS previous_day_cases,
    (new_cases - LAG(new_cases, 1) OVER (PARTITION BY location ORDER BY date)) AS difference_from_yesterday
FROM `portfolio_project`.`coviddeaths 2`
WHERE location = 'Afghanistan'
ORDER BY date;
