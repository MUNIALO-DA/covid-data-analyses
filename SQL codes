-- Case Fatality Rate (CFR): How dangerous the disease was among confirmed cases
-- Population Death Rate: How much of the country's population had died due to COVID-19 by that date.
SELECT
    Location,
    Date,    
    population,
    total_cases,
    total_deaths,
    ROUND(100 * total_deaths / total_cases, 2) AS case_fatality_rate,
    ROUND(100 * total_deaths / population, 4) AS population_death_rate
FROM portfolio_project.`coviddeaths 2`
ORDER BY location, date;
